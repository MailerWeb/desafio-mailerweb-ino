# ─────────────────────────────────────────────────────────────────────────────
# App
# ─────────────────────────────────────────────────────────────────────────────
APP_ENV=development          # development | production
DEBUG=false
BACKEND_CORS_ORIGINS=*       # produção: http://meudominio.com,https://meudominio.com

# ─────────────────────────────────────────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────────────────────────────────────────
POSTGRES_USER=user
POSTGRES_PASSWORD=pass
POSTGRES_DB=meetings
POSTGRES_HOST=db             # nome do serviço no docker-compose; use localhost fora do docker
POSTGRES_PORT=5432

# ─────────────────────────────────────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────────────────────────────────────
REDIS_HOST=redis             # nome do serviço no docker-compose; use localhost fora do docker
REDIS_PORT=6379

# ─────────────────────────────────────────────────────────────────────────────
# JWT
# ─────────────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=super-secret-key-change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# ─────────────────────────────────────────────────────────────────────────────
# SMTP
# Dev  → Mailpit (sem auth, sem TLS)
# Prod → SMTP real (Gmail, SES, Sendgrid etc.)
# ─────────────────────────────────────────────────────────────────────────────
SMTP_HOST=mailpit            # produção: smtp.sendgrid.net
SMTP_PORT=1025               # produção: 587
SMTP_FROM=noreply@meetingrooms.local
SMTP_USER=                   # produção: apikey / seu usuário SMTP
SMTP_PASSWORD=               # produção: sua senha / API key SMTP
SMTP_TLS=false               # produção: true

# ─────────────────────────────────────────────────────────────────────────────
# Celery / Outbox Worker
# ─────────────────────────────────────────────────────────────────────────────
OUTBOX_POLL_INTERVAL_SECONDS=10
